#!/command/execlineb -P
with-contenv

# Import paths and base variables
importas -S -D /home/jovyan SERVE_DIR
importas -S -D /            NB_PREFIX
importas -S -D shared       PRIMARY_GID

execline-cd ${SERVE_DIR}
foreground { s6-rmrf /var/run/shared/ttyd.sock }

# Step 1: Capture PID 1 / Docker Host-provided supplementary groups (e.g., via --group-add)
backtick -n -E HOST_GIDS { id -G }

# Step 2: Capture the native groups assigned to user jovyan in the system database (/etc/group)
backtick -n -E DB_GIDS { id -G jovyan }

# Step 3: Dynamically look up the UID of jovyan and the GID of the requested PRIMARY_GID
backtick -n -E TARGET_UID { id -u jovyan }
backtick -n -E TARGET_GID {
    ifelse { pipeline { echo ${PRIMARY_GID} } grep -qE "^[0-9]+$" }
    {
        echo ${PRIMARY_GID}
    }
    ifelse { pipeline { getent group ${PRIMARY_GID} } pipeline { cut -d: -f3 } grep -qE "." }
    {
        pipeline { getent group ${PRIMARY_GID} } cut -d: -f3
    }
    pipeline { getent group shared } cut -d: -f3
}

# Step 4: Apply the identity configuration explicitly
# -u and -g set the execution context. -G applies the combined list of supplementary groups.
s6-applyuidgid -u ${TARGET_UID} -g ${TARGET_GID} -G "${HOST_GIDS} ${DB_GIDS}"

# Set user context environments
export HOME /home/jovyan

# Format and clean up the URL base path prefix
backtick -n CLEANED_NB_PREFIX { pipeline { echo ${NB_PREFIX} } sed -E "s|/+|/|g; s|/$||" }
importas -S -D "" CLEANED_NB_PREFIX

foreground { s6-echo "INFO: starting ttyd-server..." }
fdmove -c 2 1

# Execute ttyd
ttyd --port=8886 --interface=/var/run/shared/ttyd.sock --cwd=${SERVE_DIR} --url-arg --base-path=${CLEANED_NB_PREFIX}/ttyd /bin/bash