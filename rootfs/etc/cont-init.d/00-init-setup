#!/command/with-contenv bash
# s6-overlay init script

set -euo pipefail

echo "[cont-init] Starting environment setup..."

SERVE_DIR="${SERVE_DIR:-}"
FIX_PERMS_RECURSIVE="${FIX_PERMS_RECURSIVE:-0}"
HOME_DIR="/home/jovyan"
GOLDEN_VENV="/opt/venv"

echo "[cont-init] SERVE_DIR=${SERVE_DIR:-default}"
echo "[cont-init] FIX_PERMS_RECURSIVE=${FIX_PERMS_RECURSIVE}"

# ==================================================
# Workspace / home mapping
# ==================================================

echo "[cont-init] Configuring home..."

if [[ -n "${SERVE_DIR}" ]]; then
    mkdir -p "${SERVE_DIR}"

    if mountpoint -q "${HOME_DIR}"; then
        echo "[cont-init] ${HOME_DIR} is mounted, keeping it"
    else
        echo "[cont-init] Mapping ${HOME_DIR} -> ${SERVE_DIR}"
        rm -rf "${HOME_DIR}"
        ln -sfn "${SERVE_DIR}" "${HOME_DIR}"
    fi

    if [[ "${FIX_PERMS_RECURSIVE}" == "1" ]]; then
        chown -R jovyan:shared "${SERVE_DIR}"
    else
        chown jovyan:shared "${SERVE_DIR}" || true
    fi
fi

# ==================================================
# VSCode server mapping
# ==================================================

echo "[cont-init] Configuring vscode server..."

VSCODE_DIR="/opt/vscode-server"

mkdir -p "${VSCODE_DIR}"

rm -rf "${HOME_DIR}/.vscode-server"
ln -sfn "${VSCODE_DIR}" "${HOME_DIR}/.vscode-server"

rm -rf /root/.vscode-server
ln -sfn "${VSCODE_DIR}" /root/.vscode-server

# ==================================================
# Home directories
# ==================================================

echo "[cont-init] Preparing user directories..."

for d in \
    "${HOME_DIR}/.local" \
    "${HOME_DIR}/.config" \
    "${HOME_DIR}/.cache"
do
    install -d -o jovyan -g shared -m 755 "$d" || true
done

# ==================================================
# Global bash config
# ==================================================

echo "[cont-init] Installing bash configuration..."

cat >/etc/bash.bashrc <<'EOF'
# Global container bash config

HISTCONTROL=ignoreboth:erasedups
HISTSIZE=5000
HISTFILESIZE=10000

shopt -s histappend
shopt -s checkwinsize

export VIRTUAL_ENV_DISABLE_PROMPT=1

if [ -z "${VIRTUAL_ENV:-}" ] &&
   [ -f /opt/venv/bin/activate ]; then
    source /opt/venv/bin/activate
fi

if [ -z "${_ENV_INFO_SHOWN:-}" ]; then
export _ENV_INFO_SHOWN=1

echo "--------------------------------------------------"
echo "📦 Runtime Environment"
echo "--------------------------------------------------"

echo "OS         : $(lsb_release -ds 2>/dev/null || uname -a)"

if command -v python >/dev/null 2>&1; then
    echo "Python     : $(python --version)"
fi

echo "Venv       : ${VIRTUAL_ENV:-none}"

if command -v nvidia-smi >/dev/null 2>&1; then
    echo "Driver     : $(nvidia-smi --query-gpu=driver_version --format=csv,noheader | head -n1)"
    echo "GPU(s)     :"
    nvidia-smi --query-gpu=index,name,memory.total,memory.free \
        --format=csv,noheader | sed 's/^/  - /'
else
    echo "CUDA       : not visible"
fi

echo "--------------------------------------------------"
fi

if [ -x /usr/bin/dircolors ]; then
    eval "$(dircolors -b)"
    alias ls='ls --color=auto'
    alias grep='grep --color=auto'
fi

alias l='ls -CF'
alias la='ls -A'
alias ll='ls -alF --group-directories-first'
alias lh='ls -lh --group-directories-first'

alias dfh='df -h'
alias du1='du -h --max-depth=1'
alias duh='du -sh * 2>/dev/null'

alias k='kubectl'

if ! shopt -oq posix; then
    [ -f /usr/share/bash-completion/bash_completion ] &&
        source /usr/share/bash-completion/bash_completion
fi

command -v kubectl >/dev/null 2>&1 &&
    source <(kubectl completion bash 2>/dev/null)

command -v uv >/dev/null 2>&1 &&
    source <(uv generate-shell-completion bash 2>/dev/null)

EOF

chmod 644 /etc/bash.bashrc

# ==================================================
# Prompt
# ==================================================

echo "[cont-init] Installing prompt..."

cat >/etc/container-prompt.sh <<'EOF'

[ -f /usr/lib/git-core/git-sh-prompt ] &&
    source /usr/lib/git-core/git-sh-prompt

export GIT_PS1_SHOWDIRTYSTATE=1
export GIT_PS1_SHOWUNTRACKEDFILES=1

fix_path() {
    case "$1" in
        "$HOME"*) printf "~%s" "${1#$HOME}" ;;
        *) printf "%s" "$1" ;;
    esac
}

prompt_venv() {
    if [ -n "${VIRTUAL_ENV:-}" ]; then
        printf "(%s)" "$(fix_path "$VIRTUAL_ENV")"
    fi
}

prompt_path() {
    fix_path "$PWD"
}

prompt_git() {
    declare -F __git_ps1 >/dev/null &&
        __git_ps1 " git:(%s)"
}

PS1='\[\033[01;36m\]$(prompt_venv)\[\033[00m\] \[\033[01;35m\]$(prompt_path)\[\033[00m\]
 ➜ \[\033[01;32m\]\u@\h\[\033[00m\]\[\033[01;33m\]$(prompt_git)\[\033[00m\] '

EOF

chmod 644 /etc/container-prompt.sh

# ==================================================
# User bashrc
# ==================================================

echo "[cont-init] Patching user bashrc..."

USER_BASHRC="${HOME_DIR}/.bashrc"

touch "${USER_BASHRC}"

sed -i \
'/# >>> CONTAINER_PROMPT >>>/,/# <<< CONTAINER_PROMPT <<</d' \
"${USER_BASHRC}"

cat >>"${USER_BASHRC}" <<'EOF'

# >>> CONTAINER_PROMPT >>>
[ -f /etc/container-prompt.sh ] &&
    source /etc/container-prompt.sh
# <<< CONTAINER_PROMPT <<<

EOF

chown jovyan:shared "${USER_BASHRC}"
chmod 644 "${USER_BASHRC}"

# ==================================================
# uv wrapper
# ==================================================

echo "[cont-init] Configuring uv wrapper..."

if [[ -x /usr/local/bin/uv && ! -x /usr/local/bin/uv.real ]]; then
    mv /usr/local/bin/uv /usr/local/bin/uv.real

cat >/usr/local/bin/uv <<'EOF'
#!/usr/bin/env bash

GOLDEN_VENV="/opt/venv"
CMD="$(basename "$0")"

if [[ "$CMD" == "uvx" ]]; then
    unset UV_CONSTRAINT
elif [[ "${VIRTUAL_ENV:-}" == "$GOLDEN_VENV" ]]; then
    export UV_CONSTRAINT="$GOLDEN_VENV/pinned"
else
    unset UV_CONSTRAINT
fi

exec /usr/local/bin/uv.real "$@"
EOF

    chmod +x /usr/local/bin/uv
    ln -sfn /usr/local/bin/uv /usr/local/bin/uvx
fi

# ==================================================
# pip wrapper
# ==================================================

echo "[cont-init] Configuring pip wrapper..."

if [[ -x "${GOLDEN_VENV}/bin/pip" &&
      ! -x "${GOLDEN_VENV}/bin/pip.real" ]]; then

    mv "${GOLDEN_VENV}/bin/pip" \
       "${GOLDEN_VENV}/bin/pip.real"

cat >"${GOLDEN_VENV}/bin/pip" <<'EOF'
#!/usr/bin/env bash

GOLDEN_VENV="/opt/venv"

if [[ "${VIRTUAL_ENV:-}" == "$GOLDEN_VENV" ]]; then
    export PIP_CONSTRAINT="$GOLDEN_VENV/pinned"
else
    unset PIP_CONSTRAINT
fi

exec "$GOLDEN_VENV/bin/pip.real" "$@"
EOF

    chmod +x "${GOLDEN_VENV}/bin/pip"
fi

echo "[cont-init] Environment setup complete."