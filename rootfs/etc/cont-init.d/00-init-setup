#!/command/with-contenv bash
# s6-overlay init script

set -euo pipefail

echo "[cont-init] setting up user..."

: "${PRIMARY_UID:=}"
: "${PRIMARY_GID:=}"

DEFAULT_UID="$(id -u jovyan)"
DEFAULT_GID="$(id -g jovyan)"
TARGET_UID="${PRIMARY_UID:-${DEFAULT_UID}}"
TARGET_GID="${PRIMARY_GID:-${DEFAULT_GID}}"
JOVYAN_GROUPS_BEFORE="$(id -nG jovyan | tr ' ' ',')"
EXISTING_USER_GROUPS=""

echo "[cont-init] DEFAULT_UID=${DEFAULT_UID}, DEFAULT_GID=${DEFAULT_GID}"
echo "[cont-init] TARGET_UID=${TARGET_UID}, TARGET_GID=${TARGET_GID}"

# PRIMARY_UID policy:
# - empty: keep jovyan default uid
# - provided and uid absent: remap jovyan to uid
# - provided and uid exists: rename existing uid owner to jovyan
if [ -n "${PRIMARY_UID}" ]; then
    EXISTING_USER="$(getent passwd "${TARGET_UID}" | cut -d: -f1 || true)"
    if [ -n "${EXISTING_USER}" ] && [ "${EXISTING_USER}" != "jovyan" ]; then
        EXISTING_USER_GROUPS="$(id -nG "${EXISTING_USER}" | tr ' ' ',')"
    fi

    if [ -z "${EXISTING_USER}" ]; then
        echo "[cont-init] Mapping jovyan UID ${DEFAULT_UID} -> ${TARGET_UID}"
        usermod -u "${TARGET_UID}" jovyan
    elif [ "${EXISTING_USER}" != "jovyan" ]; then
        echo "[cont-init] UID ${TARGET_UID} belongs to ${EXISTING_USER}; renaming it to jovyan"

        BACKUP_USER="jovyan_prev"
        if getent passwd "${BACKUP_USER}" >/dev/null 2>&1; then
            BACKUP_USER="jovyan_prev_${DEFAULT_UID}"
        fi

        usermod -l "${BACKUP_USER}" jovyan
        usermod -l jovyan "${EXISTING_USER}"
        usermod -d /home/jovyan -s /bin/bash jovyan
    fi
fi

# PRIMARY_GID policy:
# - empty: keep jovyan default gid
# - provided and gid absent: create a new group named "jovyan" with target gid
# - provided and gid exists with different name: rename that group to "jovyan"
# shared group is never remapped; the target gid becomes jovyan's primary gid.
if [ -n "${PRIMARY_GID}" ]; then
    EXISTING_GROUP="$(getent group "${TARGET_GID}" | cut -d: -f1 || true)"

    if [ -z "${EXISTING_GROUP}" ]; then
        echo "[cont-init] Creating group jovyan with GID ${TARGET_GID}"
        groupadd -g "${TARGET_GID}" jovyan
    elif [ "${EXISTING_GROUP}" != "jovyan" ]; then
        echo "[cont-init] Renaming group ${EXISTING_GROUP} (GID ${TARGET_GID}) -> jovyan"
        groupmod -n jovyan "${EXISTING_GROUP}"
    fi

    usermod -g "${TARGET_GID}" jovyan
fi

# Keep and merge supplementary groups on jovyan; runtime --group-add is merged in service scripts.
MERGED_GROUPS="$(
    printf '%s\n' "root,shared" "${JOVYAN_GROUPS_BEFORE}" "${EXISTING_USER_GROUPS}" \
    | tr ',' '\n' \
    | awk 'NF && !seen[$0]++' \
    | paste -sd, -
)"

if [ -n "${MERGED_GROUPS}" ]; then
    usermod -aG "${MERGED_GROUPS}" jovyan
fi


echo "[cont-init] starting environment setup..."

SERVE_DIRECTORY="${SERVE_DIRECTORY:-/home/jovyan}"
FIX_PERMS_RECURSIVE="${FIX_PERMS_RECURSIVE:-0}"

echo "[cont-init] SERVE_DIRECTORY=${SERVE_DIRECTORY:-default}"
echo "[cont-init] FIX_PERMS_RECURSIVE=${FIX_PERMS_RECURSIVE}"

# ==================================================
# Workspace setup
# ==================================================

echo "[cont-init] Configuring workspace..."

if [[ -n "${SERVE_DIRECTORY}" ]]; then
    PRIMARY_GROUP_NAME="$(id -gn jovyan)"
    install -d -o jovyan -g "${PRIMARY_GROUP_NAME}" -m 775 "${SERVE_DIRECTORY}"

    echo "[cont-init] Workspace directory: ${SERVE_DIRECTORY}"

    if [[ "${FIX_PERMS_RECURSIVE}" == "1" ]]; then
        chown -R jovyan:"${PRIMARY_GROUP_NAME}" "${SERVE_DIRECTORY}"
    else
        chown jovyan:"${PRIMARY_GROUP_NAME}" "${SERVE_DIRECTORY}" || true
    fi
fi

# ==================================================
# Global bash config
# ==================================================

echo "[cont-init] Installing bash configuration..."

cat > /etc/bash.bashrc <<'EOF'
# Global container bash config

HISTCONTROL=ignoreboth:erasedups
HISTSIZE=5000
HISTFILESIZE=10000

shopt -s histappend
shopt -s checkwinsize

export VIRTUAL_ENV_DISABLE_PROMPT=1

if [ -z "${_ENV_INFO_SHOWN:-}" ]; then
export _ENV_INFO_SHOWN=1

echo "--------------------------------------------------"
echo "📦 Runtime Environment"
echo "--------------------------------------------------"

echo "OS         : $(lsb_release -ds 2>/dev/null || uname -a)"

if command -v python >/dev/null 2>&1; then
    echo "Python     : $(python --version)"
fi

echo "Venv       : ${VIRTUAL_ENV:-none}"

if command -v nvidia-smi >/dev/null 2>&1; then
    echo "Driver     : $(nvidia-smi --query-gpu=driver_version --format=csv,noheader | head -n1)"
    echo "GPU(s)     :"
    nvidia-smi --query-gpu=index,name,memory.total,memory.free \
        --format=csv,noheader | sed 's/^/  - /'
else
    echo "CUDA       : not visible"
fi

echo "--------------------------------------------------"
fi

if [ -x /usr/bin/dircolors ]; then
    eval "$(dircolors -b)"
    alias ls='ls --color=auto'
    alias grep='grep --color=auto'
fi

alias l='ls -CF'
alias la='ls -A'
alias ll='ls -alF --group-directories-first'
alias lh='ls -lh --group-directories-first'

alias dfh='df -h'
alias du1='du -h --max-depth=1'
alias duh='du -sh * 2>/dev/null'

alias k='kubectl'

if ! shopt -oq posix; then
    [ -f /usr/share/bash-completion/bash_completion ] &&
        source /usr/share/bash-completion/bash_completion
fi

command -v kubectl >/dev/null 2>&1 &&
    source <(kubectl completion bash 2>/dev/null)

command -v uv >/dev/null 2>&1 &&
    source <(uv generate-shell-completion bash 2>/dev/null)

[ -f /etc/container-prompt.sh ] &&
    source /etc/container-prompt.sh

if [ -d /etc/bash.bashrc.d ]; then
    for f in /etc/bash.bashrc.d/*.sh; do
        [ -r "$f" ] && source "$f"
    done
fi

EOF

chmod 644 /etc/bash.bashrc

# ==================================================
# Prompt
# ==================================================

echo "[cont-init] Installing prompt..."

cat >/etc/container-prompt.sh <<'EOF'

[ -f /usr/lib/git-core/git-sh-prompt ] &&
    source /usr/lib/git-core/git-sh-prompt

export GIT_PS1_SHOWDIRTYSTATE=1
export GIT_PS1_SHOWUNTRACKEDFILES=1

fix_path() {
    case "$1" in
        "$HOME"*) printf "~%s" "${1#$HOME}" ;;
        *) printf "%s" "$1" ;;
    esac
}

prompt_venv() {
    if [ -n "${VIRTUAL_ENV:-}" ]; then
        printf "(%s)" "$(fix_path "$VIRTUAL_ENV")"
    fi
}

prompt_path() {
    fix_path "$PWD"
}

prompt_git() {
    declare -F __git_ps1 >/dev/null &&
        __git_ps1 " git:(%s)"
}

PS1='\[\033[01;36m\]$(prompt_venv)\[\033[00m\] \[\033[01;35m\]$(prompt_path)\[\033[00m\]
 ➜ \[\033[01;32m\]\u@\h\[\033[00m\]\[\033[01;33m\]$(prompt_git)\[\033[00m\] '

EOF

chmod 644 /etc/container-prompt.sh

# ==================================================
# Global bashrc.d drop-ins
# ==================================================

echo "[cont-init] Installing global bash drop-ins..."

install -d -o root -g root -m 755 /etc/bash.bashrc.d

cat >/etc/bash.bashrc.d/40-python-fallback.sh <<'EOF'
# Python environment fallback helpers.

attach_base_fallback_path() {
    local env_path="$1"
    [ -x "$env_path/bin/python" ] || return 0
    [ -x "/opt/venv/bin/python" ] || return 0

    local target_sp base_sp
    target_sp="$("$env_path/bin/python" -c "import site; print(site.getsitepackages()[0])")"
    base_sp="$(/opt/venv/bin/python -c "import site; print(site.getsitepackages()[0])")"
    # Skip if the new env shares the same site-packages as the base (e.g. env_path IS /opt/venv)
    [ "$target_sp" = "$base_sp" ] && return 0
    # Use an executable .pth line so the base path is explicitly appended at the very end of
    # sys.path; own-venv packages therefore always shadow any package that also exists in base.
    printf "import sys; _p='%s'; _p not in sys.path and sys.path.append(_p)\n" \
        "$base_sp" > "$target_sp/zz-base-fallback.pth"
}

uv() {
    if [ "$1" = "venv" ]; then
        shift
        local env_path
        command uv venv "$@"
        env_path="${@: -1}"
        [ -x "$env_path/bin/python" ] || env_path=".venv"
        attach_base_fallback_path "$env_path"
    else
        command uv "$@"
    fi
}

mkvenv() {
    uv venv "$@"
}

pyvenv() {
    local env_path
    command python -m venv "$@"
    env_path="${@: -1}"
    [ -x "$env_path/bin/python" ] || env_path=".venv"
    attach_base_fallback_path "$env_path"
}

EOF

chmod 644 /etc/bash.bashrc.d/40-python-fallback.sh

# ==================================================
# uv wrapper
# ==================================================

echo "[cont-init] Configuring uv wrapper..."

if [[ -x /usr/local/bin/uv && ! -x /usr/local/bin/uv.real ]]; then
    mv /usr/local/bin/uv /usr/local/bin/uv.real

cat > /usr/local/bin/uv <<'EOF'
#!/usr/bin/env bash

GOLDEN_VENV="/opt/venv"
CMD="$(basename "$0")"

if [[ "$CMD" == "uvx" ]]; then
    unset UV_CONSTRAINT
elif [[ "${VIRTUAL_ENV:-}" == "${GOLDEN_VENV}" ]]; then
    export UV_CONSTRAINT="${GOLDEN_VENV}/pinned"
else
    unset UV_CONSTRAINT
fi

exec /usr/local/bin/uv.real "$@"
EOF

    chmod +x /usr/local/bin/uv
    ln -sfn /usr/local/bin/uv /usr/local/bin/uvx
fi

# ==================================================
# pip wrapper
# ==================================================
echo "[cont-init] Configuring pip wrapper..."

if [[ -x "/opt/venv/bin/pip" && ! -x "/opt/venv/bin/pip.real" ]]; then
    mv "/opt/venv/bin/pip" "/opt/venv/bin/pip.real"

cat >"/opt/venv/bin/pip" <<'EOF'
#!/usr/bin/env bash

GOLDEN_VENV="/opt/venv"

if [[ "${VIRTUAL_ENV:-}" == "${GOLDEN_VENV}" ]]; then
    export PIP_CONSTRAINT="${GOLDEN_VENV}/pinned"
else
    unset PIP_CONSTRAINT
fi

exec "${GOLDEN_VENV}/bin/pip.real" "$@"
EOF

    chmod +x "/opt/venv/bin/pip"
fi

echo "[cont-init] Environment setup complete."